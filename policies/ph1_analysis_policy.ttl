@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.org/> .
@prefix dct: <http://purl.org/dc/terms/> .

# Process Analysis Policy: Analyst may USE the activities for analysis
<urn:uuid:policy-ph1-analysis> a odrl:Set ;
    dct:description "Process analysis stage: analyst may use activities for value-added classification." ;
    odrl:permission <urn:uuid:perm-ph1-analysis> .

<urn:uuid:perm-ph1-analysis> a odrl:Permission ;
    odrl:action odrl:use ;
    odrl:target ex:ph1-activities ;
    odrl:assignee ex:analyst ;
    odrl:assigner ex:process-owner .
