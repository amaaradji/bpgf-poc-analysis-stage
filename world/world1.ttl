@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.com/> .

# Current time for evaluation
<http://example.com/currentTime> odrl:dateTime "2026-02-11T00:00:00Z"^^xsd:dateTime .

# The activities asset exists
<http://example.com/ph1-activities> a odrl:Asset .

# The analyst party exists
<http://example.com/analyst> a odrl:Party .
