@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix ex: <http://example.com/> .

# Current time for evaluation
ex:currentTime odrl:dateTime "2026-02-11T00:00:00Z"^^xsd:dateTime .

